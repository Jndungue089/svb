<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="BeneditaUI.Views.SerialLogPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Monitor Serial"
    BackgroundColor="{StaticResource Background}">

    <Grid RowDefinitions="Auto,Auto,*,Auto" Padding="28,20" RowSpacing="14">

        <!-- ── Cabeçalho ─────────────────────────────── -->
        <VerticalStackLayout Grid.Row="0" Spacing="2">
            <Label Text="Monitor Serial" Style="{StaticResource PageTitle}" />
            <Label Text="Comunicação em tempo real com o ESP32" Style="{StaticResource Caption}" />
        </VerticalStackLayout>

        <!-- ── Barra de controlo ──────────────────── -->
        <Frame Grid.Row="1" Style="{StaticResource CardFrame}" Padding="16,12">
            <Grid ColumnDefinitions="Auto,Auto,Auto,Auto,*,Auto,Auto" ColumnSpacing="10">

                <Picker
                    Grid.Column="0"
                    Title="Porta COM"
                    ItemsSource="{Binding AvailablePorts}"
                    SelectedItem="{Binding SelectedPort}"
                    WidthRequest="130" />

                <Picker
                    Grid.Column="1"
                    Title="Baud Rate"
                    ItemsSource="{Binding BaudRates}"
                    SelectedItem="{Binding SelectedBaud}"
                    WidthRequest="110" />

                <Button
                    Grid.Column="2"
                    Text="{Binding IsOpen, Converter={StaticResource BoolToConnectLabelConverter}}"
                    Command="{Binding ConnectCommand}"
                    BackgroundColor="{Binding IsOpen, Converter={StaticResource BoolToColorConverter}}" />

                <Button
                    Grid.Column="3"
                    Text="↺"
                    Command="{Binding RefreshPortsCommand}"
                    Style="{StaticResource SecondaryButton}"
                    WidthRequest="44"
                    ToolTipProperties.Text="Atualizar portas" />

                <Label
                    Grid.Column="4"
                    Text="{Binding StatusMessage}"
                    Style="{StaticResource Caption}"
                    VerticalOptions="Center"
                    Margin="8,0" />

                <Button
                    Grid.Column="5"
                    Text="PING"
                    Command="{Binding PingCommand}"
                    Style="{StaticResource SecondaryButton}"
                    IsEnabled="{Binding IsOpen}" />

                <Button
                    Grid.Column="6"
                    Text="🗑 Limpar"
                    Command="{Binding ClearLogCommand}"
                    Style="{StaticResource SecondaryButton}" />
            </Grid>
        </Frame>

        <!-- ── Log viewer (terminal escuro) ─────── -->
        <Frame
            Grid.Row="2"
            Padding="0"
            CornerRadius="12"
            HasShadow="True"
            BorderColor="#1A1A2E"
            BackgroundColor="#1A1A2E">
            <CollectionView
                x:Name="LogList"
                ItemsSource="{Binding Log}"
                SelectionMode="None"
                BackgroundColor="#1A1A2E">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Grid
                            ColumnDefinitions="90,60,*"
                            Padding="12,3"
                            ColumnSpacing="6">
                            <Label
                                Text="{Binding TimeLabel}"
                                TextColor="#666680"
                                FontFamily="OpenSansRegular"
                                FontSize="11"
                                VerticalOptions="Center" />
                            <Label
                                Grid.Column="1"
                                Text="{Binding Prefix}"
                                TextColor="{Binding Color}"
                                FontAttributes="Bold"
                                FontSize="11"
                                VerticalOptions="Center" />
                            <Label
                                Grid.Column="2"
                                Text="{Binding Text}"
                                TextColor="{Binding Color}"
                                FontFamily="OpenSansRegular"
                                FontSize="12"
                                VerticalOptions="Center" />
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Frame>

        <!-- ── Envio manual ─────────────────────── -->
        <Frame Grid.Row="3" Style="{StaticResource CardFrame}" Padding="12">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                <Entry
                    Placeholder="Ex: CMD:PING  |  CMD:AUTH:5  |  CMD:PARTIES"
                    Text="{Binding ManualCommand}"
                    ReturnCommand="{Binding SendCommandCommand}"
                    BackgroundColor="#2A2A3E"
                    TextColor="White"
                    PlaceholderColor="#666680"
                    HeightRequest="40" />
                <Button
                    Grid.Column="1"
                    Text="Enviar"
                    Command="{Binding SendCommandCommand}"
                    IsEnabled="{Binding IsOpen}"
                    WidthRequest="90" />
            </Grid>
        </Frame>

    </Grid>
</ContentPage>
