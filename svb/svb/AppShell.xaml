<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="BeneditaUI.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:BeneditaUI.Views"
    Title="Benedita — Sistema de Votação"
    FlyoutBehavior="Flyout"
    FlyoutWidth="220"
    Shell.NavBarIsVisible="True">

    <Shell.FlyoutHeader>
        <Grid
            BackgroundColor="{StaticResource Primary}"
            Padding="16,24"
            RowDefinitions="Auto,Auto">
            <Label
                Text="🗳️ Benedita"
                TextColor="White"
                FontSize="22"
                FontAttributes="Bold" />
            <Label
                Grid.Row="1"
                Text="Painel de Votação"
                TextColor="#DDEEFF"
                FontSize="12" />
        </Grid>
    </Shell.FlyoutHeader>

    <!-- Dashboard -->
    <FlyoutItem Title="Dashboard" Route="dashboard">
        <ShellContent
            Title="Dashboard"
            ContentTemplate="{DataTemplate views:DashboardPage}" />
    </FlyoutItem>

    <!-- Eleitores -->
    <FlyoutItem Title="Eleitores" Route="voters">
        <ShellContent
            Title="Eleitores"
            ContentTemplate="{DataTemplate views:VotersPage}" />
    </FlyoutItem>

    <!-- Monitor Serial -->
    <FlyoutItem Title="Monitor Serial" Route="serial">
        <ShellContent
            Title="Monitor Serial"
            ContentTemplate="{DataTemplate views:SerialLogPage}" />
    </FlyoutItem>

    <!-- Configurações -->
    <FlyoutItem Title="Configurações" Route="settings">
        <ShellContent
            Title="Configurações"
            ContentTemplate="{DataTemplate views:SettingsPage}" />
    </FlyoutItem>

</Shell>
