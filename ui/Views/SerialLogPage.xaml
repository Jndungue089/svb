<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="BeneditaUI.Views.SerialLogPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Monitor Serial">

    <Grid RowDefinitions="Auto,*,Auto" Padding="16" RowSpacing="10">

        <!-- Connection toolbar -->
        <Frame Grid.Row="0" Style="{StaticResource CardFrame}" Padding="12">
            <Grid ColumnDefinitions="Auto,Auto,Auto,Auto,*,Auto,Auto" ColumnSpacing="8">

                <Picker
                    Grid.Column="0"
                    Title="Porta"
                    ItemsSource="{Binding AvailablePorts}"
                    SelectedItem="{Binding SelectedPort}"
                    WidthRequest="120" />

                <Picker
                    Grid.Column="1"
                    Title="Baud"
                    ItemsSource="{Binding BaudRates}"
                    SelectedItem="{Binding SelectedBaud}"
                    WidthRequest="100" />

                <Button
                    Grid.Column="2"
                    Text="{Binding IsOpen, Converter={StaticResource BoolToConnectLabelConverter}}"
                    Command="{Binding ConnectCommand}"
                    BackgroundColor="{Binding IsOpen, Converter={StaticResource BoolToColorConverter}}" />

                <Button
                    Grid.Column="3"
                    Text="↺"
                    Command="{Binding RefreshPortsCommand}"
                    Style="{StaticResource SecondaryButton}"
                    ToolTipProperties.Text="Atualizar lista de portas" />

                <Label
                    Grid.Column="4"
                    Text="{Binding StatusMessage}"
                    TextColor="Gray"
                    VerticalOptions="Center"
                    FontSize="13" />

                <Button
                    Grid.Column="5"
                    Text="PING"
                    Command="{Binding PingCommand}"
                    Style="{StaticResource SecondaryButton}"
                    IsEnabled="{Binding IsOpen}" />

                <Button
                    Grid.Column="6"
                    Text="🗑 Limpar"
                    Command="{Binding ClearLogCommand}"
                    Style="{StaticResource SecondaryButton}" />
            </Grid>
        </Frame>

        <!-- Log view -->
        <CollectionView
            x:Name="LogList"
            Grid.Row="1"
            ItemsSource="{Binding Log}"
            SelectionMode="None"
            BackgroundColor="#1E1E2E">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Grid
                        ColumnDefinitions="90,60,*"
                        Padding="8,2"
                        ColumnSpacing="6">
                        <Label
                            Text="{Binding TimeLabel}"
                            TextColor="#888"
                            FontFamily="OpenSansRegular"
                            FontSize="11"
                            VerticalOptions="Center" />
                        <Label
                            Grid.Column="1"
                            Text="{Binding Prefix}"
                            TextColor="{Binding Color}"
                            FontAttributes="Bold"
                            FontSize="11"
                            VerticalOptions="Center" />
                        <Label
                            Grid.Column="2"
                            Text="{Binding Text}"
                            TextColor="{Binding Color}"
                            FontFamily="OpenSansRegular"
                            FontSize="12"
                            VerticalOptions="Center" />
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Manual command input -->
        <Grid Grid.Row="2" ColumnDefinitions="*,Auto" ColumnSpacing="8">
            <Entry
                Placeholder="Ex: CMD:PING  |  CMD:AUTH:5"
                Text="{Binding ManualCommand}"
                ReturnCommand="{Binding SendCommandCommand}"
                FontFamily="OpenSansRegular"
                BackgroundColor="#2A2A3E"
                TextColor="White"
                PlaceholderColor="#555" />
            <Button
                Grid.Column="1"
                Text="Enviar"
                Command="{Binding SendCommandCommand}"
                IsEnabled="{Binding IsOpen}" />
        </Grid>

    </Grid>
</ContentPage>
